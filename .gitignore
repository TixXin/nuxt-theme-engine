# 日志与系统文件
# ------------------------------
# 日志文件
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# 操作系统文件
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

